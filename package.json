{
  "name": "production-site-crawler",
  "version": "1.0.0",
  "description": "A production-oriented web crawler take-home assignment built around a TypeScript/Node.js CLI, PostgreSQL-backed crawl state, and an external Fetch API. The implementation will crawl from a seed URL, persist fetched content by type with metadata, and support durable, resumable, concurrency-safe execution in later phases.",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "test": "vitest run",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "dev": "tsx src/cli/index.ts",
    "crawl": "tsx src/cli/index.ts crawl",
    "status": "tsx src/cli/index.ts status",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier . --check",
    "migrate": "node --import dotenv/config ./node_modules/.bin/node-pg-migrate --dir migrations",
    "migrate:up": "npm run migrate -- up",
    "migrate:down": "npm run migrate -- down",
    "migrate:create": "npm run migrate -- create",
    "test:integration": "vitest run tests/integration"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/webboy/production-site-crawler.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/webboy/production-site-crawler/issues"
  },
  "homepage": "https://github.com/webboy/production-site-crawler#readme",
  "dependencies": {
    "commander": "^15.0.0",
    "dotenv": "^17.4.2",
    "node-pg-migrate": "^8.0.4",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/pg": "^8.20.0",
    "eslint": "^10.6.0",
    "prettier": "^3.9.4",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=20"
  }
}
