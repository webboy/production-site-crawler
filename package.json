{
  "name": "production-site-crawler",
  "version": "1.0.0",
  "description": "A production-oriented TypeScript/Node.js CLI crawler with PostgreSQL-backed crawl state, resumable workers, content processing, and status reporting.",
  "bin": {
    "production-site-crawler": "src/cli/index.ts"
  },
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:coverage": "vitest run --coverage",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "dev": "tsx src/cli/index.ts",
    "crawl": "tsx src/cli/index.ts crawl",
    "status": "tsx src/cli/index.ts status",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier . --check",
    "migrate": "node --import dotenv/config ./node_modules/.bin/node-pg-migrate --dir migrations",
    "migrate:up": "npm run migrate -- up",
    "migrate:down": "npm run migrate -- down",
    "migrate:create": "npm run migrate -- create"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/webboy/production-site-crawler.git"
  },
  "keywords": [],
  "author": "Nemanja",
  "license": "MIT",
  "type": "module",
  "bugs": {
    "url": "https://github.com/webboy/production-site-crawler/issues"
  },
  "homepage": "https://github.com/webboy/production-site-crawler#readme",
  "dependencies": {
    "cheerio": "^1.2.0",
    "commander": "^15.0.0",
    "dotenv": "^17.4.2",
    "image-size": "^2.0.2",
    "node-pg-migrate": "^8.0.4",
    "pdf-parse": "^2.4.5",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "tldts": "^7.4.6"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/pg": "^8.20.0",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.6.0",
    "prettier": "^3.9.4",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=20"
  }
}
