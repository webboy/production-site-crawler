# PostgreSQL connection. DATABASE_URL is preferred when set.
DATABASE_URL=postgres://crawler:crawler@localhost:5432/production_site_crawler
PGHOST=localhost
PGPORT=5432
PGDATABASE=production_site_crawler
PGUSER=crawler
PGPASSWORD=crawler

# External Fetch API
FETCH_API_BASE_URL=http://mock-api.mock.com/fetch

# Logging
LOG_LEVEL=info

# Crawl defaults
CONCURRENCY=5
MAX_URLS=1000
MAX_DEPTH=5
MAX_BYTES=104857600
MAX_RUNTIME_SECONDS=3600
OUTPUT_DIR=output

# Retry and rate limiting
RETRY_BASE_DELAY_MS=5000
RETRY_MAX_DELAY_MS=300000
RETRY_JITTER_RATIO=0.25
RATE_LIMIT_DELAY_MS=150
RATE_LIMIT_DEFAULT_PAUSE_MS=5000
